<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="appTurismo.Views.RegistrarIncidenciaPage"
             Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Salir" Command="{Binding CerrarSesionCommand}" Order="Primary" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="18" Spacing="14">
            <Label Text="Registrar incidencia"
                   FontSize="25"
                   FontAttributes="Bold" />

            <Border Padding="12" Stroke="#FFE082" StrokeThickness="1" BackgroundColor="#FFF8E1">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding TuristaNombre}" FontAttributes="Bold" FontSize="17" />
                    <Label Text="{Binding CheckpointNombre, StringFormat='Checkpoint: {0}'}"
                           TextColor="#666666" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Tipo de incidencia" FontAttributes="Bold" />
            <Picker Title="Selecciona el motivo"
                    ItemsSource="{Binding Tipos}"
                    SelectedItem="{Binding TipoSeleccionado}"
                    ItemDisplayBinding="{Binding Etiqueta}" />

            <Label Text="Descripcion" FontAttributes="Bold" />
            <Editor Text="{Binding Descripcion}"
                    Placeholder="Describe lo ocurrido y la accion tomada por el guia."
                    HeightRequest="110"
                    AutoSize="TextChanges" />

            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                <VerticalStackLayout>
                    <Label Text="Requiere atencion"
                           FontAttributes="Bold" />
                    <Label Text="Señala casos que deban atenderse con prioridad."
                           FontSize="12"
                           TextColor="#666666" />
                </VerticalStackLayout>
                <Switch Grid.Column="1"
                        IsToggled="{Binding RequiereAtencion}"
                        VerticalOptions="Center" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                <VerticalStackLayout>
                    <Label Text="Retirar del recorrido"
                           FontAttributes="Bold" />
                    <Label Text="Dejara de aparecer en los siguientes pases de lista."
                           FontSize="12"
                           TextColor="#666666" />
                </VerticalStackLayout>
                <Switch Grid.Column="1"
                        IsToggled="{Binding RetirarParticipante}"
                        VerticalOptions="Center" />
            </Grid>

            <Button Text="Guardar incidencia"
                    Command="{Binding GuardarIncidenciaCommand}"
                    IsEnabled="{Binding IsNotBusy}"
                    BackgroundColor="#F57C00"
                    TextColor="White"
                    HeightRequest="50" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
