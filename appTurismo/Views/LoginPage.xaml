<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:appTurismo.ViewModels"
             x:Class="appTurismo.Views.LoginPage"
             Shell.FlyoutItemIsVisible="False"
             Shell.NavBarIsVisible="False"
             Title="Login">

    <VerticalStackLayout Padding="30" VerticalOptions="Center" Spacing="15">
        <Label Text="¡Bienvenido!" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,0,0,20"/>

        <Entry Placeholder="Correo Electrónico" Text="{Binding Email}" Keyboard="Email" HeightRequest="50"/>
        <Entry Placeholder="Contraseña" Text="{Binding Password}" IsPassword="True" HeightRequest="50"/>

        <Button Text="Ingresar" Command="{Binding LoginCommand}" IsEnabled="{Binding IsNotBusy}" Margin="0,15,0,0" HeightRequest="50"/>

        <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,10,0,0">
            <Label Text="¿No tienes cuenta?" VerticalOptions="Center"/>
            <Button Text="Regístrate" Command="{Binding GoToRegisterCommand}" BackgroundColor="Transparent" TextColor="DarkCyan"/>
        </HorizontalStackLayout>

        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center"/>
    </VerticalStackLayout>
</ContentPage>