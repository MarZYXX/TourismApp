<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="appTurismo.Views.AdminPage"
             Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Salir" Command="{Binding CerrarSesionCommand}" Order="Primary" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*" Padding="18" RowSpacing="14">
        <VerticalStackLayout Grid.Row="0" Spacing="13">
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Mis Viajes" FontSize="26" FontAttributes="Bold" />
                    <Label Text="Planea, opera y consulta tu historial de recorridos."
                           FontSize="13"
                           TextColor="#666666" />
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        Text="+ Nuevo"
                        Command="{Binding IrCrearViajeCommand}"
                        BackgroundColor="#2196F3"
                        TextColor="White"
                        CornerRadius="8" />
            </Grid>

            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
                <Border Grid.Column="0" Padding="9" BackgroundColor="#FFF8E1" Stroke="#FFE082" StrokeThickness="1">
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="{Binding TotalPlanificados}" FontSize="20" FontAttributes="Bold" TextColor="#F57C00" />
                        <Label Text="Planificados" FontSize="11" TextColor="#555555" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" Padding="9" BackgroundColor="#E3F2FD" Stroke="#90CAF9" StrokeThickness="1">
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="{Binding TotalEnCurso}" FontSize="20" FontAttributes="Bold" TextColor="#1565C0" />
                        <Label Text="En curso" FontSize="11" TextColor="#555555" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="2" Padding="9" BackgroundColor="#E8F5E9" Stroke="#A5D6A7" StrokeThickness="1">
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="{Binding TotalFinalizados}" FontSize="20" FontAttributes="Bold" TextColor="#2E7D32" />
                        <Label Text="Finalizados" FontSize="11" TextColor="#555555" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="3" Padding="9" BackgroundColor="#F5F5F5" Stroke="#BDBDBD" StrokeThickness="1">
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="{Binding TotalCancelados}" FontSize="20" FontAttributes="Bold" TextColor="#616161" />
                        <Label Text="Cancelados" FontSize="10" TextColor="#555555" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="8">
                    <Button Text="Todos"
                            Command="{Binding FiltrarViajesCommand}"
                            CommandParameter="Todos"
                            BackgroundColor="#455A64"
                            TextColor="White" />
                    <Button Text="Planificados"
                            Command="{Binding FiltrarViajesCommand}"
                            CommandParameter="Plan"
                            BackgroundColor="#FFB300"
                            TextColor="White" />
                    <Button Text="En curso"
                            Command="{Binding FiltrarViajesCommand}"
                            CommandParameter="Activo"
                            BackgroundColor="#1976D2"
                            TextColor="White" />
                    <Button Text="Finalizados"
                            Command="{Binding FiltrarViajesCommand}"
                            CommandParameter="Completado"
                            BackgroundColor="#388E3C"
                            TextColor="White" />
                    <Button Text="Cancelados"
                            Command="{Binding FiltrarViajesCommand}"
                            CommandParameter="Cancelado"
                            BackgroundColor="#757575"
                            TextColor="White" />
                </HorizontalStackLayout>
            </ScrollView>

            <Grid ColumnDefinitions="*,Auto">
                <Label Text="{Binding TituloFiltro}"
                       FontSize="18"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />
                <ActivityIndicator Grid.Column="1"
                                   IsVisible="{Binding IsBusy}"
                                   IsRunning="{Binding IsBusy}"
                                   Color="#2196F3" />
            </Grid>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding ViajesFiltrados}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <Border Padding="18" Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="#FAFAFA">
                    <Label Text="No hay viajes en esta categoria."
                           TextColor="#666666"
                           HorizontalTextAlignment="Center" />
                </Border>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,12" Padding="14" Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="White">
                        <VerticalStackLayout Spacing="9">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding Nombre}"
                                       FontSize="19"
                                       FontAttributes="Bold"
                                       TextColor="#1B5E20" />
                                <Label Grid.Column="1"
                                       Text="{Binding Estado}"
                                       FontAttributes="Bold"
                                       TextColor="#F57C00"
                                       VerticalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding Estado}" Value="Activo">
                                            <Setter Property="TextColor" Value="#1565C0" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding Estado}" Value="Completado">
                                            <Setter Property="TextColor" Value="#2E7D32" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding Estado}" Value="Cancelado">
                                            <Setter Property="TextColor" Value="#616161" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Grid>

                            <Label Text="{Binding FechaInicio, StringFormat='Inicio: {0:dd/MM/yyyy HH:mm}'}"
                                   FontSize="13"
                                   TextColor="#555555" />
                            <Label Text="{Binding PuntoEncuentro, StringFormat='Encuentro: {0}'}"
                                   FontSize="13"
                                   TextColor="#555555" />

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button Text="Ver ruta"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.VerMapaCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#FF9800"
                                        TextColor="White" />
                                <Button Grid.Column="1"
                                        Text="Ver detalle"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.VerDetalleCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#2196F3"
                                        TextColor="White" />
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8"
                                  IsVisible="{Binding EsPlanificado}">
                                <Button Text="Editar"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditarViajeCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#1976D2"
                                        TextColor="White" />
                                <Button Grid.Column="1"
                                        Text="Cancelar"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CancelarViajeCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#E53935"
                                        TextColor="White" />
                            </Grid>

                            <Button Text="Reactivar viaje"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ReactivarViajeCommand}"
                                    CommandParameter="{Binding .}"
                                    IsVisible="{Binding EsCancelado}"
                                    BackgroundColor="#4CAF50"
                                    TextColor="White" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
