<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="appTurismo.Views.RegisterPage"
             Shell.FlyoutItemIsVisible="False"
             Shell.NavBarIsVisible="False"
             Title="TourTrack">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="12" VerticalOptions="Center">
            <Image Source="tourtrack_logo.png"
                   HeightRequest="105"
                   WidthRequest="105"
                   Aspect="AspectFit"
                   HorizontalOptions="Center" />
            <Label Text="TourTrack"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#1565C0"
                   HorizontalOptions="Center" />
            <Label Text="Crear cuenta" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,0,0,15"/>

            <Entry Placeholder="Nombre" Text="{Binding Nombre}" HeightRequest="50"/>
            <Entry Placeholder="Apellido Paterno" Text="{Binding ApellidoPaterno}" HeightRequest="50"/>
            <Entry Placeholder="Apellido Materno" Text="{Binding ApellidoMaterno}" HeightRequest="50"/>
            <Entry Placeholder="Teléfono" Text="{Binding Telefono}" Keyboard="Numeric" MaxLength="10" HeightRequest="50"/>
            <Entry Placeholder="Correo" Text="{Binding Email}" Keyboard="Email" HeightRequest="50"/>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                <Entry x:Name="PasswordEntry"
                       Placeholder="Contraseña"
                       Text="{Binding Password}"
                       IsPassword="True"
                       HeightRequest="50" />
                <ImageButton x:Name="TogglePasswordButton"
                             Grid.Column="1"
                             Source="eye.svg"
                             Clicked="TogglePassword_Clicked"
                             BackgroundColor="Transparent"
                             WidthRequest="46"
                             HeightRequest="50"
                             Padding="10"
                             SemanticProperties.Description="Mostrar contraseña" />
            </Grid>

            <Label Text="Selecciona tu tipo de cuenta:" FontAttributes="Bold" Margin="0,10,0,0" HorizontalOptions="Center"/>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,5,0,15">
                <Button Grid.Column="0" 
                        Text="Cliente / Turista" 
                        Command="{Binding SelectRoleCommand}" 
                        CommandParameter="turista"
                        HeightRequest="45"
                        BackgroundColor="{Binding TuristaButtonColor}"
                        TextColor="White"/>

                <Button Grid.Column="1" 
                        Text="Guía de turismo"
                        Command="{Binding SelectRoleCommand}" 
                        CommandParameter="guia"
                        HeightRequest="45"
                        BackgroundColor="{Binding GuiaButtonColor}"
                        TextColor="White"/>
            </Grid>

            <Button Text="Registrar" Command="{Binding RegisterCommand}" IsEnabled="{Binding IsNotBusy}" Margin="0,5,0,0" HeightRequest="50"/>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,10,0,0">
                <Label Text="¿Ya tienes cuenta?" VerticalOptions="Center"/>
                <Button Text="Inicia sesión" Command="{Binding GoToLoginCommand}" BackgroundColor="Transparent" TextColor="DarkCyan"/>
            </HorizontalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
